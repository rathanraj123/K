# ====================================================
# AgriCosmo AI Platform - Backend Environment Template
# ====================================================

# Application Info
PROJECT_NAME="AgriCosmo Enterprise"
APP_NAME="AgriCosmo Enterprise"
APP_VERSION="1.0.0"
ENVIRONMENT="development" # development | production | testing
SECRET_KEY="generate_a_secure_random_key_here_for_prod"
JWT_SECRET_KEY="generate_another_secure_random_key_here_for_prod"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration (Async PostgreSQL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agricosmo
# DATABASE_URL=postgresql+asyncpg://postgres:your_db_password@localhost:5432/agricosmo

# Redis
REDIS_URL=redis://localhost:6379/0

# Supabase (Storage & Auth Integration)
SUPABASE_URL="https://your-supabase-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Third-Party APIs
GROQ_API_KEY="your-groq-api-key"
HUGGINGFACE_API_KEY="your-huggingface-api-key"
OPENWEATHER_API_KEY="your-openweather-api-key"
NEWS_API_KEY="your-news-api-key"
DATA_GOV_API_KEY="your-datagov-api-key"

# CORS and URL Settings
FRONTEND_URL="http://localhost:5173"
API_BASE_URL="http://localhost:8000/api/v1"
# RENDER_EXTERNAL_URL=
