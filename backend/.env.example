# ==========================================
# AgriCosmo AI - Backend Production .env 
# ==========================================

# 1. Core Application Configuration
ENVIRONMENT=production
APP_VERSION=1.0.0
# MUST be set to a strong random string (e.g., openssl rand -hex 32)
SECRET_KEY=your_secure_random_secret_key_here
LOG_LEVEL=INFO
# If using a lower-tier Render plan, set to true to disable heavy ML models on startup
LOW_MEMORY_MODE=false

# 2. Database Connection (PostgreSQL via Supabase)
# Must be standard postgresql URL format. The app will auto-upgrade to asyncpg.
DATABASE_URL=postgresql://postgres.your_project:your_password@aws-0-region.pooler.supabase.com:6543/postgres

# 3. Redis (Required for Caching and Background Tasks)
REDIS_URL=rediss://default:your_redis_password@your-redis-host.upstash.io:6379

# 4. Supabase Storage Integration
SUPABASE_URL=https://your_project.supabase.co
# IMPORTANT: Use the Service Role Key for backend administration, not the Anon Key!
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# 5. Third Party APIs (Required for core functionality)
# Groq is required for the LLM AI Analysis engine
GROQ_API_KEY=gsk_your_groq_api_key_here

# 6. Optional Third Party APIs
# Required if Elasticsearch features are used
ELASTICSEARCH_URL=
ELASTICSEARCH_API_KEY=

# OpenWeatherMap API for accurate weather analytics
OPENWEATHER_API_KEY=

# 7. CORS Configuration
# Format as a strict comma-separated list of your frontend URLs
BACKEND_CORS_ORIGINS=https://your-agricosmo-frontend.vercel.app,https://www.yourdomain.com
