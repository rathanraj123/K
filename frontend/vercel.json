{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/((?!assets/|static/|favicon.ico|manifest.json).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
