# ==========================================
# AgriCosmo AI - Frontend Production .env 
# ==========================================

# 1. API Configuration
# Point this to your Render production backend URL
VITE_API_URL=https://your-agricosmo-backend.onrender.com/api/v1

# 2. Supabase Configuration (Required for Storage & Auth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# 3. Environment Context
VITE_ENVIRONMENT=production
